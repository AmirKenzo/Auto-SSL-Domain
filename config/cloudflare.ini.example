# OPTIONAL — only if you want automatic DNS (not required)
# Copy to /etc/autossl/cloudflare.ini and uncomment ONE option:
# chmod 600 /etc/autossl/cloudflare.ini
#
# Without this file, wildcard/DNS mode uses manual TXT records.

# dns_cloudflare_api_token = YOUR_CLOUDFLARE_API_TOKEN

# dns_cloudflare_email = admin@example.com
# dns_cloudflare_api_key = YOUR_GLOBAL_API_KEY
